rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar: verifica se o usuário é admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Função auxiliar: verifica se está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users - admin pode ler/escrever, usuário pode ler o próprio
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Colaboradores - admin tem acesso total, colaborador pode editar campos limitados do próprio perfil
    match /colaboradores/{colaboradorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if isAuthenticated() &&
        resource.data.email == request.auth.token.email &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['fotoUrl', 'telefone', 'gestor', 'linkedin', 'github', 'credly', 'updatedAt']);

      // Histórico (sub-coleção)
      match /historico/{historicoId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Equipamentos - admin tem acesso total, colaborador pode ler
    match /equipamentos/{equipId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Benefícios - admin tem acesso total, colaborador pode ler
    match /beneficios/{beneficioId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Férias - admin tem acesso total, colaborador pode ler
    match /ferias/{feriaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Config - admin pode ler/escrever
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Fechamentos - admin pode ler/escrever
    match /fechamentos/{fechId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
